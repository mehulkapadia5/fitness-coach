{
  "version": "1.0",
  "name": "Health overview",
  "template": "{\"type\":\"Card\",\"size\":\"md\",\"children\":[{\"type\":\"Col\",\"gap\":2,\"children\":[{%- set _c -%},{\"type\":\"Col\",\"gap\":1,\"children\":[{\"type\":\"Title\",\"value\":{{ ((user ~ \", \" ~ today_day_of_week)) | tojson }},\"size\":\"md\"},{\"type\":\"Caption\",\"value\":{{ ((today ~ \" · \" ~ current_time_local ~ \" · \" ~ timezone)) | tojson }}}]}{%-if (active_targets | length) > 0 -%},{\"type\":\"Fragment\",\"children\":[{\"type\":\"Divider\",\"flush\":true},{\"type\":\"Row\",\"wrap\":\"wrap\",\"gap\":3,\"align\":\"stretch\",\"children\":[{%- set _c -%}{%-for item in active_targets -%},{\"type\":\"Box\",\"key\":{{ (item.id) | tojson }},\"flex\":1,\"minWidth\":150,\"padding\":3,\"radius\":\"lg\",\"border\":1,\"background\":\"surface\",\"children\":[{\"type\":\"Col\",\"gap\":2,\"children\":[{\"type\":\"Title\",\"value\":{{ (item.label) | tojson }},\"size\":\"sm\"},{\"type\":\"Text\",\"value\":{{ ((item.current_value ~ \" / \" ~ item.target ~ \" \" ~ item.unit)) | tojson }},\"size\":\"xl\",\"weight\":\"semibold\"},{\"type\":\"Col\",\"gap\":1,\"children\":[{\"type\":\"Box\",\"height\":8,\"background\":\"alpha-10\",\"radius\":\"full\",\"children\":[{\"type\":\"Box\",\"height\":\"100%\",\"width\":{{ ((item.progressPct ~ \"%\")) | tojson }},\"background\":{{ (item.accent) | tojson }},\"radius\":\"full\"}]},{\"type\":\"Caption\",\"value\":{{ ((item.comparison ~ \", \" ~ item.period)) | tojson }},\"color\":\"secondary\"}]}]}]}{%-endfor-%}{%- endset -%}{{- (_c[1:] if _c and _c[0] == ',' else _c) -}}]}]}{%-else-%}{%-endif-%},{\"type\":\"Divider\",\"flush\":true},{\"type\":\"Title\",\"value\":\"Today's meals\",\"size\":\"sm\"}{%-if (today_meals | length) == 0 -%},{\"type\":\"Caption\",\"value\":\"Nothing logged yet today\"}{%-else-%},{\"type\":\"ListView\",\"children\":[{%- set _c -%}{%-for m in today_meals -%},{\"type\":\"ListViewItem\",\"key\":{{ (m.id) | tojson }},\"gap\":3,\"align\":\"stretch\",\"children\":[{\"type\":\"Col\",\"gap\":0,\"children\":[{\"type\":\"Caption\",\"value\":{{ (m.time) | tojson }}},{\"type\":\"Text\",\"value\":{{ (m.description) | tojson }},\"size\":\"sm\"},{\"type\":\"Caption\",\"value\":{{ (m.portion_assumed) | tojson }},\"color\":\"secondary\"}]},{\"type\":\"Spacer\"},{\"type\":\"Badge\",\"label\":{{ ((m.calories_kcal ~ \" kcal\")) | tojson }},\"color\":\"info\"}]}{%-endfor-%}{%- endset -%}{{- (_c[1:] if _c and _c[0] == ',' else _c) -}}]}{%-endif-%},{\"type\":\"Divider\",\"flush\":true},{\"type\":\"Title\",\"value\":\"Last 7 days\",\"size\":\"sm\"},{\"type\":\"Row\",\"gap\":2,\"wrap\":\"wrap\",\"children\":[{%- set _c -%}{%-for w in last_7_days_workouts -%},{\"type\":\"Badge\",\"key\":{{ (w.id) | tojson }},\"label\":{{ (w.type) | tojson }},\"size\":\"sm\"}{%-endfor-%}{%- endset -%}{{- (_c[1:] if _c and _c[0] == ',' else _c) -}}]}{%- endset -%}{{- (_c[1:] if _c and _c[0] == ',' else _c) -}}]}]}",
  "jsonSchema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
      "user": {
        "type": "string"
      },
      "today_day_of_week": {
        "type": "string"
      },
      "today": {
        "type": "string"
      },
      "current_time_local": {
        "type": "string"
      },
      "timezone": {
        "type": "string"
      },
      "active_targets": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string"
            },
            "label": {
              "type": "string"
            },
            "current_value": {
              "type": "number"
            },
            "target": {
              "type": "number"
            },
            "unit": {
              "type": "string"
            },
            "comparison": {
              "type": "string"
            },
            "period": {
              "type": "string"
            },
            "progressPct": {
              "type": "number"
            },
            "accent": {
              "type": "string",
              "enum": [
                "blue-500",
                "green-500",
                "purple-500",
                "orange-500"
              ]
            }
          },
          "required": [
            "id",
            "label",
            "current_value",
            "target",
            "unit",
            "comparison",
            "period",
            "progressPct",
            "accent"
          ],
          "additionalProperties": false
        }
      },
      "today_meals": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string"
            },
            "time": {
              "type": "string"
            },
            "description": {
              "type": "string"
            },
            "portion_assumed": {
              "type": "string"
            },
            "calories_kcal": {
              "type": "number"
            }
          },
          "required": [
            "id",
            "time",
            "description",
            "portion_assumed",
            "calories_kcal"
          ],
          "additionalProperties": false
        }
      },
      "last_7_days_workouts": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string"
            },
            "type": {
              "type": "string"
            }
          },
          "required": [
            "id",
            "type"
          ],
          "additionalProperties": false
        }
      }
    },
    "required": [
      "user",
      "today_day_of_week",
      "today",
      "current_time_local",
      "timezone",
      "active_targets",
      "today_meals",
      "last_7_days_workouts"
    ],
    "additionalProperties": false
  },
