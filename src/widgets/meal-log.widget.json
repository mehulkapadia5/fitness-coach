  "template": "{\"type\":\"Card\",\"size\":\"sm\",\"padding\":4,\"children\":[{\"type\":\"Col\",\"gap\":3,\"children\":[{%- set _c -%},{\"type\":\"Box\",\"background\":{\"light\":\"#A7F0BA\",\"dark\":\"#4ade80\"},\"radius\":\"md\",\"padding\":3,\"children\":[{\"type\":\"Row\",\"children\":[{\"type\":\"Title\",\"value\":{{ (description) | tojson }},\"size\":\"md\"},{\"type\":\"Spacer\"},{\"type\":\"Badge\",\"label\":{{ ((calories_kcal ~ \" kcal\")) | tojson }},\"color\":\"success\",\"size\":\"lg\",\"variant\":\"solid\"}]}]},{\"type\":\"Caption\",\"value\":{{ ((\"Assumed: \" ~ portion_assumed)) | tojson }}},{\"type\":\"Divider\"},{\"type\":\"Row\",\"gap\":3,\"children\":[{\"type\":\"Box\",\"flex\":1,\"background\":\"surface-secondary\",\"radius\":\"md\",\"padding\":3,\"align\":\"center\",\"children\":[{\"type\":\"Text\",\"value\":{{ ((protein_g ~ \" g\")) | tojson }},\"size\":\"xl\",\"weight\":\"semibold\"},{\"type\":\"Caption\",\"value\":\"protein\"}]},{\"type\":\"Box\",\"flex\":1,\"background\":\"surface-secondary\",\"radius\":\"md\",\"padding\":3,\"align\":\"center\",\"children\":[{\"type\":\"Text\",\"value\":{{ (time) | tojson }},\"size\":\"xl\",\"weight\":\"semibold\"},{\"type\":\"Caption\",\"value\":\"logged\"}]}]}{%-if daily_target_calories != null -%},{\"type\":\"Col\",\"gap\":2,\"children\":[{\"type\":\"Caption\",\"value\":\"Today's calories\"},{\"type\":\"Row\",\"children\":[{\"type\":\"Text\",\"value\":{{ ((daily_total_calories ~ \" / \" ~ daily_target_calories ~ \" kcal\")) | tojson }},\"weight\":\"semibold\"},{\"type\":\"Spacer\"},{\"type\":\"Caption\",\"value\":{% if daily_total_calories > daily_target_calories %}{{ (((daily_total_calories - daily_target_calories) ~ \" over\")) | tojson }}{% else %}{{ (((daily_target_calories - daily_total_calories) ~ \" kcal headroom\")) | tojson }}{% endif %}}]},{\"type\":\"Box\",\"height\":8,\"radius\":\"full\",\"background\":\"alpha-10\",\"children\":[{\"type\":\"Box\",\"height\":\"100%\",\"radius\":\"full\",\"width\":{{ ((\"$\" ~ (((daily_total_calories / daily_target_calories) * 100) if daily_total_calories / daily_target_calories * 100 <= 100 else 100) ~ \"%\")) | tojson }},\"background\":{% if daily_total_calories / daily_target_calories <= 0.9 %}\"green-400\"{% else %}{% if daily_total_calories / daily_target_calories <= 1 %}\"orange-400\"{% else %}\"red-400\"{% endif %}{% endif %}}]}]}{%-else-%}{%-endif-%}{%-if daily_target_protein_g != null -%},{\"type\":\"Col\",\"gap\":2,\"children\":[{\"type\":\"Caption\",\"value\":\"Today's protein\"},{\"type\":\"Row\",\"children\":[{\"type\":\"Text\",\"value\":{{ ((daily_total_protein_g ~ \" / \" ~ daily_target_protein_g ~ \" g\")) | tojson }},\"weight\":\"semibold\"},{\"type\":\"Spacer\"},{\"type\":\"Caption\",\"value\":{% if daily_total_protein_g >= daily_target_protein_g %}\"goal hit\"{% else %}{{ (((daily_target_protein_g - daily_total_protein_g) ~ \" g to go\")) | tojson }}{% endif %}}]},{\"type\":\"Box\",\"height\":8,\"radius\":\"full\",\"background\":\"alpha-10\",\"children\":[{\"type\":\"Box\",\"height\":\"100%\",\"radius\":\"full\",\"width\":{{ ((\"$\" ~ (((daily_total_protein_g / daily_target_protein_g) * 100) if daily_total_protein_g / daily_target_protein_g * 100 <= 100 else 100) ~ \"%\")) | tojson }},\"background\":{% if daily_total_protein_g / daily_target_protein_g >= 1 %}\"green-400\"{% else %}\"blue-400\"{% endif %}}]}]}{%-else-%}{%-endif-%},{\"type\":\"Divider\"},{\"type\":\"Caption\",\"value\":\"Tell me if the assumed portion is wrong and I'll adjust.\"}{%- endset -%}{{- (_c[1:] if _c and _c[0] == ',' else _c) -}}]}]}",
